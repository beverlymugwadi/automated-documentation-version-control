# ───────────────────────────────────────────────────────────
# ADGVC server environment
# Copy to .env and fill in. Every variable the server reads is listed here.
# (.env is gitignored — never put real secrets in this example file.)
# ───────────────────────────────────────────────────────────

# HTTP port the API listens on.
PORT=4000

# MongoDB connection string. If absent (or MOCK_MODE=true), the server falls
# back to in-memory data so it always runs for a demo.
MONGODB_URI=mongodb://127.0.0.1:27017/adgvc

# Secret used to sign/verify JWTs. Use a long random string in production.
JWT_SECRET=replace-me-with-a-long-random-secret

# GitHub OAuth app credentials (version control integration).
# Leave blank to run without GitHub (a demo login is used instead).
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/github/callback
# OAuth scopes requested from GitHub (comma-separated).
GITHUB_SCOPE=read:user,public_repo

# Where the browser client is served (used for CORS + OAuth redirects).
CLIENT_URL=http://localhost:5173

# 32-byte key used to encrypt stored OAuth tokens at rest.
# Optional in dev (falls back to JWT_SECRET). Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# Storage mode. true = in-memory (no DB needed). GitHub OAuth works in either
# mode as long as the client id/secret above are set.
MOCK_MODE=true

# Optional LLM synthesis stage. If set, generation also returns an
# "AI-enhanced" rewrite of the rule-based output. Leave blank to disable
# (the app returns rule-based docs only and flags llmAvailable: false).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
