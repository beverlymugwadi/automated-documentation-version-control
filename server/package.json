{
  "name": "@adgvc/server",
  "version": "0.1.0",
  "private": true,
  "description": "ADGVC API server (Express + TypeScript)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --clear src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "seed": "ts-node-dev --transpile-only src/scripts/seed.ts"
  },
  "dependencies": {
    "@babel/parser": "^7.26.3",
    "@babel/traverse": "^7.26.4",
    "bcryptjs": "^2.4.3",
    "comment-parser": "^1.4.7",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "docx": "^9.0.3",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.3",
    "pdfkit": "^0.15.2",
    "simple-git": "^3.27.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@babel/types": "^7.26.3",
    "@types/babel__traverse": "^7.20.6",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.5",
    "@types/pdfkit": "^0.13.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
